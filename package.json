{
  "name": "youtube-listen-mode",
  "version": "1.11.4",
  "description": "A browser extension to listen to YouTube videos in the background.",
  "main": "src/content.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/vuon9/youtube-listen-mode"
  },
  "scripts": {
    "test": "nyc cucumber-js --format json:cucumber_report.json && node ops/cucumber-report.js",
    "version-sync": "node ops/sync-version.js",
    "prepare": "git config core.hooksPath .githooks",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "keywords": [
    "youtube",
    "listen",
    "chrome",
    "extension"
  ],
  "author": "Vuong",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cucumber/cucumber": "^12.5.0",
    "cucumber-html-reporter": "^6.0.0",
    "jest": "^30.2.0",
    "nyc": "^17.1.0"
  }
}
